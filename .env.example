# Environment Variables — Pizza Ordering System
# Copy to .env and fill in real values. Never commit .env to version control.

# ---------------------------------------------------------------------------
# Aiven MySQL (required)
# ---------------------------------------------------------------------------
AIVEN_DB_URL=jdbc:mysql://YOUR_HOST:PORT/defaultdb?ssl-mode=REQUIRED&serverTimezone=UTC
AIVEN_DB_USERNAME=avnadmin
AIVEN_DB_PASSWORD=

# ---------------------------------------------------------------------------
# Cloudinary (required for admin pizza image upload)
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------------------------------------------------------------------------
# Default Admin (optional — BOTH must be set to seed first admin)
# If either is missing, NO admin account is created at startup.
# ---------------------------------------------------------------------------
ADMIN_DEFAULT_NAME=Administrator
ADMIN_DEFAULT_EMAIL=
ADMIN_DEFAULT_PASSWORD=
